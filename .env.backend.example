# 后端环境变量配置（独立部署）
# 复制此文件为 .env.backend 并按实际环境修改；
# 若为内网部署，也可复制为 .env.backend.internal
# 本示例按“IP 直连 + 443 对外 + 本地知识库 + DashScope 兼容网关”口径填写

# ========== 应用运行 ==========
DEBUG=false
TZ=Asia/Shanghai
HOST=0.0.0.0
PORT=443
WORKERS=4

# ========== 跨域 ==========
# 按实际前端访问地址调整，多个来源用逗号分隔
ALLOWED_ORIGINS=http://10.62.16.251,http://10.62.16.251:8000,https://10.62.16.251

# ========== 大模型 / Embedding ==========
# 公网 DashScope 兼容网关示例；若接内网网关，请改为实际内网地址
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=sk-please-replace-with-real-key
LLM_MODEL=qwen-turbo
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4000
LLM_TIMEOUT=120
LLM_MAX_CONTEXT_TOKENS=32000
LLM_INPUT_MAX_TOKENS=25000
LLM_CHUNK_OVERLAP_PARAGRAPHS=2
ENABLE_LLM_CHUNKING=true

# Embedding 与 LLM 共用网关时可保持一致；若有独立 embedding 网关请改成实际地址
EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_STYLE=openai
EMBEDDING_MODEL=text-embedding-v2

# ========== 知识库 ==========
KNOWLEDGE_ENABLED=true
KNOWLEDGE_VECTOR_STORE=local
# 如需启用 Milvus，再按实际环境取消注释并填写
# MILVUS_HOST=127.0.0.1
# MILVUS_PORT=19530

# ========== 文件与任务 ==========
MAX_UPLOAD_SIZE=100
ALLOWED_EXTENSIONS=.docx,.doc,.pdf,.txt,.xlsx,.xls
TASK_RETENTION_DAYS=7

# ========== 鉴权 ==========
JWT_SECRET=change_me_to_random_string
JWT_EXPIRE_MINUTES=120
ADMIN_API_KEY=change_me_to_random_admin_key

# ========== 可选功能开关（按需开启） ==========
ENABLE_V27_PROFILE_SCHEMA=true
ENABLE_V27_RUNTIME=true
ENABLE_SERVICE_GOVERNANCE_IMPORT=true
ENABLE_SYSTEM_CATALOG_PROFILE_INIT=true
RUNTIME_MEMORY_QUERY_LIMIT=200
RUNTIME_EXECUTION_RETENTION_DAYS=180
MEMORY_RETENTION_DAYS=3650

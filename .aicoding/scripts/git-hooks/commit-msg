#!/bin/bash
# aicoding-hooks-managed
# Git commit-msg dispatcher: Git-Hook 1 (格式校验) + Git-Hook 2 (CR-ID 校验)

SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
REPO_ROOT=$(git rev-parse --show-toplevel)

# 优先使用绝对路径（生产环境），回退到相对路径（测试环境）
if [ -f "${REPO_ROOT}/.aicoding/scripts/lib/common.sh" ]; then
  # shellcheck source=../../lib/common.sh
  source "${REPO_ROOT}/.aicoding/scripts/lib/common.sh"
else
  # shellcheck source=../lib/common.sh
  source "${SCRIPT_DIR}/../lib/common.sh"
fi
aicoding_load_config

# --- Git-Hook 1: commit-msg 阶段前缀校验 ---
MSG=$(head -1 "$1")
if echo "$MSG" | grep -qE '^\[(CR-[0-9]{8}-[0-9]{3})\] '; then :
elif echo "$MSG" | grep -qE '^(feat|fix|docs|test|refactor|chore)(\([^)]+\))?: '; then :
elif echo "$MSG" | grep -qE '^(Merge|Revert|fixup!|squash!) '; then :
else
  echo "❌ commit message 格式错误"
  echo "   允许的格式："
  echo "   1. <type>: <描述>  或  <type>(<scope>): <描述>"
  echo "      type: feat|fix|docs|test|refactor|chore"
  echo "   2. [CR-YYYYMMDD-NNN] <描述>"
  echo "   3. Merge/Revert/fixup!/squash! 前缀"
  exit 1
fi

# --- 单版本策略：禁止一次提交同时触碰多个版本目录 ---
STAGED=$(git diff --cached --name-only)
aicoding_detect_version_dir_from_files "$STAGED" || true
VERSION_DIR_COUNT=$(printf '%s\n' "${AICODING_VERSION_DIRS:-}" | sed '/^$/d' | wc -l | tr -d ' ')
if [ "${VERSION_DIR_COUNT:-0}" -gt 1 ]; then
  echo "❌ 检测到多版本目录同时暂存；当前框架仅支持单版本提交"
  echo "   命中的版本目录："
  printf '%s\n' "$AICODING_VERSION_DIRS" | sed 's/^/     /'
  exit 1
fi

# --- Hotfix 场景强制 fix: 前缀 ---
HOTFIX_VERSION_DIR="${AICODING_VERSION_DIR:-}"
if [ -n "$HOTFIX_VERSION_DIR" ]; then
  HOTFIX_STATUS_FILE="${HOTFIX_VERSION_DIR}status.md"
  HOTFIX_CHANGE_LEVEL=""
  if [ -f "$HOTFIX_STATUS_FILE" ]; then
    HOTFIX_CHANGE_LEVEL=$(git show ":$HOTFIX_STATUS_FILE" 2>/dev/null | awk '
      NR==1 && $0!="---" {exit}
      NR==1 {next}
      /^---$/ {exit}
      /^_change_level:/ {sub(/^_change_level:[[:space:]]*/, ""); gsub(/[[:space:]]+$/, ""); print; exit}
    ')
  fi
  if [ "$HOTFIX_CHANGE_LEVEL" = "hotfix" ]; then
    if ! echo "$MSG" | grep -qE '^\[CR-[0-9]{8}-[0-9]{3}\] ' && \
       ! echo "$MSG" | grep -qE '^fix(\([^)]+\))?: ' && \
       ! echo "$MSG" | grep -qE '^(Merge|Revert|fixup!|squash!) '; then
      echo "❌ hotfix 提交的 commit message 前缀必须为 fix: 或 fix(scope):（当前：$(echo "$MSG" | head -c 40)…）"
      exit 1
    fi
  fi
fi

# 判断 staged 文件是否命中 CR 影响范围
cr_scope_matches_file() {
  local staged_file="$1"
  local scope="$2"
  [ -n "$scope" ] || return 1
  scope=$(printf '%s' "$scope" | sed 's#^\./##;s#/$##')
  staged_file=$(printf '%s' "$staged_file" | sed 's#^\./##')

  # 支持 glob（如 src/**/*.ts）
  if printf '%s' "$scope" | grep -qE '[*?\[]'; then
    case "$staged_file" in
      $scope) return 0 ;;
    esac
  fi

  # 目录前缀
  if printf '%s' "$scope" | grep -q '/'; then
    case "$staged_file" in
      "$scope"|"$scope"/*) return 0 ;;
    esac
  fi

  # 文件名兜底
  [ "$staged_file" = "$scope" ] && return 0
  [ "$(basename "$staged_file")" = "$scope" ] && return 0
  return 1
}

# --- Git-Hook 2: commit-msg CR-ID 校验（条件触发） ---
# 严格从暂存区探测版本目录，绑定当前变更所属版本，防止 code-only commit 绕过 CR 追溯
VERSION_DIR="${AICODING_VERSION_DIR:-}"
STATUS_FILE=""

if [ -z "$VERSION_DIR" ]; then
  # 从暂存区探测版本目录
  staged_status=""
  while IFS= read -r staged_file; do
    [ -z "$staged_file" ] && continue
    [ "$(basename "$staged_file")" = "status.md" ] || continue
    aicoding_extract_version_dir_from_path "$staged_file" >/dev/null 2>&1 || continue
    staged_status="$staged_file"
    break
  done < <(git diff --cached --name-only --diff-filter=AM)
  if [ -n "$staged_status" ]; then
    VERSION_DIR=$(dirname "$staged_status")/
    STATUS_FILE="$staged_status"
  else
    # 尝试从其他暂存的版本文档推断
    any_staged_doc=""
    while IFS= read -r staged_file; do
      [ -z "$staged_file" ] && continue
      aicoding_extract_version_dir_from_path "$staged_file" >/dev/null 2>&1 || continue
      any_staged_doc="$staged_file"
      break
    done < <(git diff --cached --name-only --diff-filter=AM)
    if [ -n "$any_staged_doc" ]; then
      VERSION_DIR=$(aicoding_extract_version_dir_from_path "$any_staged_doc")
      STATUS_FILE="${VERSION_DIR}status.md"
    else
      # 纯代码提交：尝试从最新版本目录推断（防止绕过 CR 追溯）
      latest_version_dir=$(aicoding_latest_version_dir "$REPO_ROOT" || true)
      if [ -n "$latest_version_dir" ]; then
        VERSION_DIR="${latest_version_dir}"
        STATUS_FILE="${VERSION_DIR}status.md"
      fi
    fi
  fi
else
  STATUS_FILE="${VERSION_DIR}status.md"
fi

if [ -n "$STATUS_FILE" ] && aicoding_staged_exists "$STATUS_FILE"; then
  # 严格从暂存区读取，不回退到工作树
  STATUS_CONTENT=$(git show ":$STATUS_FILE" 2>/dev/null)
  ACTIVE_CRS=$(echo "$STATUS_CONTENT" | awk -F'|' '
    {
      gsub(/^[ \t]+|[ \t]+$/, "", $2);
      gsub(/^[ \t]+|[ \t]+$/, "", $3);
      gsub(/[ \t]/, "", $3);
      if ($2 ~ /^CR-[0-9]{8}-[0-9]{3}$/ && ($3 == "Accepted" || $3 == "InProgress"))
        print $2
    }
  ')
  if [ -n "$ACTIVE_CRS" ]; then
    FULL_MSG=$(cat "$1")

    # 优先按 CR 影响范围映射本次暂存文件 → 必含 CR-ID
    REQUIRED_CRS=""
    tmp_dir=$(mktemp -d 2>/dev/null || mktemp -d -t aicoding-commit-msg)
    while IFS= read -r CR; do
      [ -z "$CR" ] && continue
      CR_FILE="${VERSION_DIR}cr/${CR}.md"
      # 严格从暂存区读取 CR 文件，不回退到工作树
      if aicoding_staged_exists "$CR_FILE"; then
        CR_CONTENT=$(git show ":$CR_FILE" 2>/dev/null)
      else
        CR_CONTENT=""
      fi
      [ -n "$CR_CONTENT" ] || continue

      tmp_cr="${tmp_dir}/${CR}.md"
      printf '%s\n' "$CR_CONTENT" > "$tmp_cr"
      CR_SCOPES=$(aicoding_extract_cr_impact_paths "$tmp_cr")
      [ -n "$CR_SCOPES" ] || continue

      matched=false
      while IFS= read -r sf; do
        [ -z "$sf" ] && continue
        while IFS= read -r scope; do
          [ -z "$scope" ] && continue
          if cr_scope_matches_file "$sf" "$scope"; then
            matched=true
            break
          fi
        done <<< "$CR_SCOPES"
        [ "$matched" = true ] && break
      done <<< "$STAGED"

      if [ "$matched" = true ]; then
        REQUIRED_CRS="${REQUIRED_CRS}\n${CR}"
      fi
    done <<< "$ACTIVE_CRS"
    rm -rf "$tmp_dir"

    REQUIRED_CRS=$(printf '%b' "$REQUIRED_CRS" | sed '/^$/d' | LC_ALL=C sort -u || true)
    if [ -n "$REQUIRED_CRS" ]; then
      MISSING_CRS=""
      while IFS= read -r CR; do
        [ -z "$CR" ] && continue
        echo "$FULL_MSG" | grep -q "$CR" || MISSING_CRS="${MISSING_CRS}\n  - ${CR}"
      done <<< "$REQUIRED_CRS"
      if [ -n "$MISSING_CRS" ]; then
        echo "❌ commit message 缺少受影响 CR-ID（按暂存文件与 CR 影响范围映射）："
        echo -e "$MISSING_CRS"
        exit 1
      fi
    else
      # 回退策略：无法映射时至少包含一个 Active CR
      FOUND=false
      for CR in $ACTIVE_CRS; do
        if echo "$FULL_MSG" | grep -q "$CR"; then FOUND=true; break; fi
      done
      if [ "$FOUND" = false ]; then
        echo "❌ 存在 Active CR，commit message 必须包含 CR-ID"
        echo "   Active CRs:"
        echo "$ACTIVE_CRS" | sed 's/^/     /'
        exit 1
      fi
    fi
  fi
fi

exit 0

#!/bin/bash
# aicoding-hooks-managed
# Git post-commit dispatcher: 加载公共库后依次执行 warnings/ 下的模块
# 注意：不启用 set -e，避免 grep 无匹配（退出码 1）中断后续 Warning

SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
REPO_ROOT=$(git rev-parse --show-toplevel)

# 优先使用绝对路径（生产环境），回退到相对路径（测试环境）
if [ -f "${REPO_ROOT}/.aicoding/scripts/lib/common.sh" ]; then
  source "${REPO_ROOT}/.aicoding/scripts/lib/common.sh"
else
  source "${SCRIPT_DIR}/../lib/common.sh"
fi
aicoding_load_config
aicoding_gate_log_init

# === 公共基础设施（供 warning 模块使用的全局变量） ===
CHANGED=$(git diff-tree --no-commit-id --name-only -r HEAD)
VERSION_DIR=$(echo "$CHANGED" | grep -oE 'docs/v[0-9]+\.[0-9]+/' | head -1)
# 不涉及版本目录的提交，不做 fallback（避免关联到错误版本）
if [ -z "$VERSION_DIR" ]; then
  exit 0
fi
STATUS_FILE="${VERSION_DIR}status.md"
AICODING_STATUS_FILE="$STATUS_FILE"
WARN_CAPTURE_FILE=$(mktemp 2>/dev/null || mktemp -t aicoding-post-commit-warn)
WARNING_LOG_FILE=$(aicoding_gate_warning_log_path)
export WARN_CAPTURE_FILE WARNING_LOG_FILE
warn() {
  local msg="$1"
  echo "⚠️  [post-commit] ${msg}"
  printf '%s [post-commit] %s\n' "$(date '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo 'unknown-time')" "${msg}" >> "$WARNING_LOG_FILE" 2>/dev/null || true
  printf '%s\n' "${msg}" >> "$WARN_CAPTURE_FILE" 2>/dev/null || true
}

# === 依次执行 warnings/ 下的模块 ===
# 使用子 shell 执行，避免模块中的 exit 终止整个 dispatcher
WARNINGS_DIR="${SCRIPT_DIR}/warnings"
if [ -d "$WARNINGS_DIR" ]; then
  for w in "$WARNINGS_DIR"/w*.sh; do
    [ -f "$w" ] || continue
    ( source "$w" )
  done
fi

REVIEW_ROUND=$(aicoding_yaml_value "_review_round" "$STATUS_FILE")
if [ -n "$REVIEW_ROUND" ] && echo "$REVIEW_ROUND" | grep -qE '^[0-9]+$'; then
  if [ "$REVIEW_ROUND" -gt 3 ]; then
    warn "W23: 当前 _review_round=${REVIEW_ROUND}（同阶段连续审查 > 3），建议暂停并请求人工确认"
  fi
fi

if ! aicoding_precommit_evidence_matches_current_head; then
  warn "W24: 未匹配到当前提交对应的 pre-commit 通过证据（疑似 --no-verify 或门禁绕过），请补充审计说明。"
fi

WARN_COUNT=$(wc -l < "$WARN_CAPTURE_FILE" 2>/dev/null | tr -d ' ' || echo 0)
REQC_WARN_COUNT=$(grep -cE 'REQ-C|REQC|禁止项' "$WARN_CAPTURE_FILE" 2>/dev/null || true)
if [ "${WARN_COUNT:-0}" -gt 0 ]; then
  echo "⚠️  [post-commit] 本次提交触发 ${WARN_COUNT} 个警告，其中 ${REQC_WARN_COUNT:-0} 个与 REQ-C/禁止项相关。"
fi
rm -f "$WARN_CAPTURE_FILE" 2>/dev/null || true

exit 0

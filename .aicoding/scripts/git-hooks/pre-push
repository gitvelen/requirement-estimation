#!/bin/bash
# aicoding-hooks-managed
# Git pre-push: direct-push protection + completed release gate

set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
if [ -x "${REPO_ROOT}/.aicoding/scripts/check_release_gate.sh" ]; then
  exec "${REPO_ROOT}/.aicoding/scripts/check_release_gate.sh" pre-push "$@"
elif [ -x "${REPO_ROOT}/scripts/check_release_gate.sh" ]; then
  exec "${REPO_ROOT}/scripts/check_release_gate.sh" pre-push "$@"
fi

echo "❌ 缺少共享 release gate 脚本：scripts/check_release_gate.sh"
exit 1

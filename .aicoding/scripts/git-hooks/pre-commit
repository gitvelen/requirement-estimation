# --- requirements.md 结构硬校验（唯一性/外键归属）---
REQ_FILES=$(echo "$STAGED" | grep 'requirements\.md$' || true)
if [ -n "$REQ_FILES" ]; then
  while IFS= read -r rf; do
    [ -z "$rf" ] && continue
    aicoding_run_gate critical "requirements-integrity" validate_requirements_integrity "$rf" || exit 1
  done <<< "$REQ_FILES"
fi

# --- CR 影响分析硬门禁（Phase 00）---
CR_FILES=$(
  printf '%s\n' "$STAGED" \
    | while IFS= read -r staged_file; do
        [ -z "$staged_file" ] && continue
        aicoding_extract_version_dir_from_path "$staged_file" >/dev/null 2>&1 || continue
        case "$staged_file" in
          docs/*/cr/CR-[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]-[0-9][0-9][0-9].md)
            printf '%s\n' "$staged_file"
            ;;
        esac
      done
)
if [ -n "$CR_FILES" ]; then
  while IFS= read -r crf; do
    [ -z "$crf" ] && continue
    aicoding_run_gate critical "cr-impact-matrix" validate_cr_impact_matrix "$crf" || exit 1
  done <<< "$CR_FILES"
fi

# --- Git-Hook 3: .env / 密钥文件泄露拦截 ---
BLOCKED=""
while IFS= read -r file; do
  [ -z "$file" ] && continue
  base=$(basename "$file")
  case "$base" in
    .env.example|.env.template|.env.sample)   continue ;;
    .env|.env.local|.env.production|.env.*)    BLOCKED="$BLOCKED\n  $file" ;;
    credentials.json|service-account.json)     BLOCKED="$BLOCKED\n  $file" ;;
    *.pem|*.key)                               BLOCKED="$BLOCKED\n  $file" ;;
    id_rsa|id_ed25519|id_ecdsa|id_dsa)         BLOCKED="$BLOCKED\n  $file" ;;
  esac
done <<< "$STAGED"

if [ -n "$BLOCKED" ]; then
  echo "❌ 检测到敏感文件即将被提交："
  echo -e "$BLOCKED"
  echo "   请将其加入 .gitignore 或从暂存区移除"
  echo "   （白名单：.env.example / .env.template / .env.sample 不拦截）"
  exit 1
fi

# --- Git-Hook 4: status.md YAML front matter 完整性 ---
STATUS_FILES=$(echo "$STAGED" | grep 'status\.md$' || true)
if [ -n "$STATUS_FILES" ]; then
  while IFS= read -r f; do
    [ -z "$f" ] && continue
    CONTENT=$(git show ":$f" 2>/dev/null) || continue
    FIRST_LINE=$(echo "$CONTENT" | head -1)
    if [ "$FIRST_LINE" != "---" ]; then
      echo "❌ $f 第 1 行必须是 ---（YAML front matter 起始标记）"
      exit 1
    fi
    HAS_END_MARKER=$(echo "$CONTENT" | awk 'NR==1{next} /^---$/{print 1; exit}')
    if [ -z "$HAS_END_MARKER" ]; then
      echo "❌ $f 的 YAML front matter 未闭合（缺少第二个 ---）"
      exit 1
    fi
    FRONT_MATTER=$(echo "$CONTENT" | awk 'NR==1{next} /^---$/{exit} {print}')
    if [ -z "$FRONT_MATTER" ]; then
      echo "❌ $f 缺少 YAML front matter 内容（--- 块为空或未闭合）"
      exit 1
    fi
    for field in _baseline _current _workflow_mode _run_status _change_status _phase; do
      if ! echo "$FRONT_MATTER" | grep -q "^${field}:"; then
        echo "❌ $f 的 YAML front matter 中缺少 ${field} 字段"
        exit 1
      fi
      VALUE=$(echo "$FRONT_MATTER" | grep "^${field}:" | sed "s/^${field}:[[:space:]]*//" | tr -d '[:space:]')
      if [ -z "$VALUE" ]; then
        echo "❌ $f 的 ${field} 值为空"
        exit 1
      fi
    done

    BASELINE=$(yaml_value_from_block "$FRONT_MATTER" "_baseline")
    WORKFLOW_MODE=$(yaml_value_from_block "$FRONT_MATTER" "_workflow_mode")
    RUN_STATUS=$(yaml_value_from_block "$FRONT_MATTER" "_run_status")
    CHANGE_STATUS=$(yaml_value_from_block "$FRONT_MATTER" "_change_status")
    CURRENT_PHASE=$(aicoding_normalize_phase "$(yaml_value_from_block "$FRONT_MATTER" "_phase")")
    CHANGE_LEVEL=$(yaml_value_from_block "$FRONT_MATTER" "_change_level")
    REVIEW_ROUND=$(yaml_value_from_block "$FRONT_MATTER" "_review_round")
    if [ -z "$REVIEW_ROUND" ]; then
      REVIEW_ROUND=0
      aicoding_gate_log_warning "${f}: _review_round 缺失，兼容期按 0 处理；请回填模板字段"
      echo "⚠️  [gate:status-review-round] ${f}: _review_round 缺失，兼容期按 0 处理" >&2
    fi

    aicoding_enum_contains "$WORKFLOW_MODE" $AICODING_ENUM_WORKFLOW_MODE || {
      echo "❌ $f: _workflow_mode 值非法（期望 manual/semi-auto/auto，当前：${WORKFLOW_MODE:-<empty>}）"
      exit 1
    }
    aicoding_enum_contains "$RUN_STATUS" $AICODING_ENUM_RUN_STATUS || {
      echo "❌ $f: _run_status 值非法（期望 running/paused/wait_confirm/wait_feedback/completed，当前：${RUN_STATUS:-<empty>}）"
      exit 1
    }
    aicoding_enum_contains "$CHANGE_STATUS" $AICODING_ENUM_CHANGE_STATUS || {
      echo "❌ $f: _change_status 值非法（期望 in_progress/done，当前：${CHANGE_STATUS:-<empty>}）"
      exit 1
    }
    aicoding_enum_contains "$CURRENT_PHASE" $AICODING_ENUM_PHASE || {
      echo "❌ $f: _phase 值非法（当前：${CURRENT_PHASE:-<empty>}）"
      exit 1
    }
    aicoding_is_version_tag "$BASELINE" || {
      echo "❌ $f: _baseline 必须为可识别版本 tag（匹配 ${AICODING_VERSION_DIR_PATTERN}，当前：${BASELINE:-<empty>}）"
      exit 1
    }
    if [ -z "$CHANGE_LEVEL" ]; then
      CHANGE_LEVEL="major"
      aicoding_gate_log_warning "${f}: _change_level 缺失，按兼容期默认 major 处理"
      echo "⚠️  [gate:status-enum] ${f}: _change_level 缺失，兼容期按 major 处理" >&2
    else
      aicoding_enum_contains "$CHANGE_LEVEL" $AICODING_ENUM_CHANGE_LEVEL || {
        echo "❌ $f: _change_level 值非法（当前：${CHANGE_LEVEL}）"
        exit 1
      }
    fi

    validate_status_table_consistency "$f" "$CONTENT" "$CURRENT_PHASE" "$CHANGE_STATUS" "$WORKFLOW_MODE" "$RUN_STATUS" "$CHANGE_LEVEL" || exit 1

    OLD_PHASE=$(aicoding_normalize_phase "$(git show "HEAD:$f" 2>/dev/null | awk '
      NR==1 && $0!="---" {exit}
      NR==1 {in_front=1; next}
      in_front && $0=="---" {exit}
      in_front && /^_phase:/ {sub(/^_phase:[[:space:]]*/, "", $0); gsub(/[[:space:]]+$/, "", $0); print; exit}
    ')")

    # --- _workflow_mode 与 _phase 映射一致性校验 ---
    EXPECTED_WF_MODE=""
    if [ "$CHANGE_LEVEL" = "hotfix" ] && [ "$CURRENT_PHASE" = "Hotfix" ]; then
      EXPECTED_WF_MODE="auto"
    else
      case "$CURRENT_PHASE" in
        ChangeManagement|Proposal|Requirements) EXPECTED_WF_MODE="manual" ;;
        Design|Planning|Implementation|Testing) EXPECTED_WF_MODE="auto" ;;
        Deployment) EXPECTED_WF_MODE="semi-auto" ;;
        Hotfix) EXPECTED_WF_MODE="auto" ;;
      esac
    fi
    if [ -n "$EXPECTED_WF_MODE" ] && [ "$WORKFLOW_MODE" != "$EXPECTED_WF_MODE" ]; then
      echo "❌ $f: _phase=$CURRENT_PHASE 要求 _workflow_mode=$EXPECTED_WF_MODE，但实际为 ${WORKFLOW_MODE}（参见 ai_workflow.md 映射规则）"
      exit 1
    fi

    if [ "$CHANGE_STATUS" = "done" ] && [ "$RUN_STATUS" != "completed" ]; then
      echo "❌ $f: _change_status=done 时要求 _run_status=completed（当前：${RUN_STATUS}）"
      exit 1
    fi
    if [ "$RUN_STATUS" = "completed" ] && [ "$CHANGE_STATUS" != "done" ]; then
      echo "❌ $f: _run_status=completed 时要求 _change_status=done（当前：${CHANGE_STATUS}）"
      exit 1
    fi

    if [ "$CHANGE_LEVEL" = "hotfix" ]; then
      aicoding_bool_is_true "$AICODING_ENABLE_HOTFIX" || {
        echo "❌ $f: _change_level=hotfix 但配置 enable_hotfix=false"
        exit 1
      }
      hotfix_diff_count_check "$f" || exit 1
      hotfix_reqc_boundary_check "$f" || exit 1
      hotfix_sensitive_boundary_check "$f" || exit 1
    elif [ "$CHANGE_LEVEL" = "minor" ]; then
      minor_diff_count_check "$f" || exit 1
      minor_new_gwt_count_check "$f" || exit 1
      minor_reqc_boundary_check "$f" || exit 1
    fi

    echo "$REVIEW_ROUND" | grep -qE '^[0-9]+$' || {
      echo "❌ $f: _review_round 必须为非负整数（当前：${REVIEW_ROUND}）"
      exit 1
    }
    if [ "$REVIEW_ROUND" -gt 5 ] && [ "$RUN_STATUS" != "wait_confirm" ] && [ "$CHANGE_LEVEL" != "hotfix" ]; then
      echo "❌ $f: 同一阶段审查轮次超过 5（_review_round=${REVIEW_ROUND}），请先切换 _run_status: wait_confirm 并请求人工确认（hotfix 例外：不受此限制）"
      exit 1
    fi

    # --- Git-Hook 7: 阶段出口门禁 ---
    VERSION_DIR=$(aicoding_extract_version_dir_from_path "$f" || true)
    [ -z "$VERSION_DIR" ] && continue
    [ -z "$CURRENT_PHASE" ] && continue

    # 检查是否有阶段推进（对比暂存区 vs HEAD）
    if [ -z "$OLD_PHASE" ]; then
      if [ "$CURRENT_PHASE" = "ChangeManagement" ]; then
        continue
      fi
      if [ "$CURRENT_PHASE" = "Proposal" ]; then
        # 检查 Active CR 状态合法性
        ACTIVE_CRS_CHECK=$(status_active_crs_from_content "$CONTENT" 2>&1)
        INVALID_STATUS=$(echo "$ACTIVE_CRS_CHECK" | grep "^INVALID_CR_STATUS:" || true)
        if [ -n "$INVALID_STATUS" ]; then
          echo "❌ $f: Active CR 列表包含非法状态的 CR："
          echo "$INVALID_STATUS" | while IFS=: read -r _ cr_id status; do
            echo "   - $cr_id: 状态 $status 不允许出现在 Active CR 列表（只允许 Accepted/InProgress）"
          done
          echo "   Idea 状态应登记在 Idea池；Implemented/Dropped/Suspended 应从 Active 列表移除"
          exit 1
        fi
        ACTIVE_CRS=$(echo "$ACTIVE_CRS_CHECK" | grep -v "^INVALID_CR_STATUS:" || true)
        if [ -z "$ACTIVE_CRS" ]; then
          continue
        fi
        echo "❌ 新建 status.md 若从 Proposal 开始，必须表示\"新版本启动\"（Proposal + 无 Active CR）；当前检测到 Active CR，请从 ChangeManagement 开始"
        exit 1
      fi
      echo "❌ 新建 status.md 的 _phase 只允许从 ChangeManagement 开始；新版本启动可在无 Active CR 时从 Proposal 开始（当前：$CURRENT_PHASE）"
      exit 1
    fi
    [ "$OLD_PHASE" = "$CURRENT_PHASE" ] && continue

    HOTFIX_PHASE_TRANSITION=false
    if [ "$CHANGE_LEVEL" = "hotfix" ] && { [ "$CURRENT_PHASE" = "Hotfix" ] || [ "$OLD_PHASE" = "Hotfix" ]; }; then
      HOTFIX_PHASE_TRANSITION=true
    fi

    if [ "$REVIEW_ROUND" -ne 0 ] && [ "$CHANGE_LEVEL" != "hotfix" ]; then
      echo "❌ $f: 检测到阶段切换（${OLD_PHASE} → ${CURRENT_PHASE}），_review_round 必须重置为 0（当前：${REVIEW_ROUND}）（hotfix 例外：不受此限制）"
      exit 1
    fi

    OLD_RANK=$(aicoding_phase_rank "$OLD_PHASE")
    NEW_RANK=$(aicoding_phase_rank "$CURRENT_PHASE")
    if [ "$HOTFIX_PHASE_TRANSITION" = true ]; then
      if [ "$OLD_PHASE" = "Hotfix" ] && [ "$CURRENT_PHASE" != "Hotfix" ]; then
        validate_hotfix_test_evidence "$CONTENT" || exit 1
      fi
      echo "ℹ️  [gate:hotfix] Hotfix 阶段切换：${OLD_PHASE} → ${CURRENT_PHASE}" >&2
      continue
    fi
    if [ "$NEW_RANK" -lt "$OLD_RANK" ]; then
      DROP=$((OLD_RANK - NEW_RANK))
      if [ "$CURRENT_PHASE" = "ChangeManagement" ]; then
        aicoding_gate_log_warning "阶段回退到 ChangeManagement：${f} ${OLD_PHASE} -> ${CURRENT_PHASE}"
        echo "⚠️  [gate:phase-transition] 检测到回退到 ChangeManagement：${OLD_PHASE} → ${CURRENT_PHASE}（允许版本内范围重收敛，已记录）" >&2
        continue
      fi
      if [ "$DROP" -gt 2 ]; then
        echo "❌ 检测到大幅阶段降级（${OLD_PHASE} → ${CURRENT_PHASE}，跨度 ${DROP}），已阻断。请人工确认后再调整。"
        exit 1
      fi
      aicoding_gate_log_warning "阶段降级：${f} ${OLD_PHASE} -> ${CURRENT_PHASE}"
      echo "⚠️  [gate:phase-transition] 检测到阶段降级：${OLD_PHASE} → ${CURRENT_PHASE}（已记录）" >&2
      continue
    fi
    [ "$NEW_RANK" -eq "$OLD_RANK" ] && continue

    # 相邻阶段校验：前进跨度 >1 硬拦截
    # Minor 允许跳过 Design/Planning（Requirements → Implementation），见 ai_workflow.md
    FORWARD_JUMP=$((NEW_RANK - OLD_RANK))
    if [ "$FORWARD_JUMP" -gt 1 ]; then
      if [ "$CHANGE_LEVEL" = "minor" ] && [ "$OLD_PHASE" = "Requirements" ] && [ "$CURRENT_PHASE" = "Implementation" ]; then
        echo "ℹ️  [gate:phase-transition] Minor 变更跳过 Design/Planning（Requirements → Implementation）" >&2
      else
        echo "❌ 阶段跳跃（${OLD_PHASE} → ${CURRENT_PHASE}，跨度 ${FORWARD_JUMP}）：只允许推进到相邻的下一阶段，不允许跳跃。"
        exit 1
      fi
    fi

    STATUS_CURRENT_REF=$(echo "$FRONT_MATTER" | grep '^_current:' | sed 's/^_current:[[:space:]]*//' | tr -d '[:space:]')

    run_result_gates_for_transition "$OLD_PHASE" "$CURRENT_PHASE" "$f" || exit 1

    # Hotfix 兼容态：允许仅声明 hotfix 变更级别，但未切换到独立 Hotfix 阶段
    if [ "$CHANGE_LEVEL" = "hotfix" ]; then
      continue
    fi

    # 产出物存在性检查
    GATE_MISSING=""
    check_gate_file() {
      aicoding_staged_exists "${VERSION_DIR}$1" || GATE_MISSING="${GATE_MISSING}\n  - $1"
    }

    while IFS= read -r required_doc; do
      [ -z "$required_doc" ] && continue
      check_gate_file "$required_doc"
    done < <(aicoding_phase_exit_required "$OLD_PHASE" "$CHANGE_LEVEL")

    case "$OLD_PHASE" in
      ChangeManagement)
        # 质量债务硬门禁：ChangeManagement → Proposal 推进时检查
        if [ "$CURRENT_PHASE" = "Proposal" ]; then
          if [ -x "${SCRIPT_DIR}/../check_quality_debt.sh" ]; then
            echo "🔍 检查质量债务（ChangeManagement → Proposal 阶段推进）..."
            "${SCRIPT_DIR}/../check_quality_debt.sh" || {
              echo "❌ 质量债务检查失败，阻断阶段推进"
              echo "   请先处理上一版本债务并将高风险债务降到阈值以下后再启动新版本"
              exit 1
            }
          fi
        fi
        ;;
      Requirements)
        aicoding_run_gate critical "phase-exit:requirements" validate_constraints_confirmation "${VERSION_DIR}review_requirements.md" "${VERSION_DIR}requirements.md" "${VERSION_DIR}proposal.md" || exit 1
        aicoding_run_gate critical "phase-exit:proposal-coverage" validate_proposal_coverage "${VERSION_DIR}proposal.md" "${VERSION_DIR}requirements.md" || exit 1
        # 检查证据清单
        has_evidence_checklist "${VERSION_DIR}review_requirements.md" || {
          echo "❌ 阶段推进失败：${VERSION_DIR}review_requirements.md 缺少'证据清单'段落或内容为空"
          echo "   请在 review 文件中添加'## 证据清单'段落，列出验证命令和输出（不允许仅包含占位符）"
          exit 1
        }
        ;;
      Design)
        aicoding_run_gate critical "phase-exit:design-trace" validate_design_trace_coverage "${VERSION_DIR}requirements.md" "${VERSION_DIR}design.md" || exit 1
        aicoding_run_gate critical "phase-exit:design-review" validate_lightweight_review "${VERSION_DIR}review_design.md" || exit 1
        # 检查证据清单
        has_evidence_checklist "${VERSION_DIR}review_design.md" || {
          echo "❌ 阶段推进失败：${VERSION_DIR}review_design.md 缺少'证据清单'段落或内容为空"
          echo "   请在 review 文件中添加'## 证据清单'段落，列出验证命令和输出（不允许仅包含占位符）"
          exit 1
        }
        ;;
      Planning)
        aicoding_run_gate critical "phase-exit:planning-coverage" validate_plan_reverse_coverage "${VERSION_DIR}requirements.md" "${VERSION_DIR}plan.md" || exit 1
        aicoding_run_gate critical "phase-exit:planning-review" validate_lightweight_review "${VERSION_DIR}review_planning.md" || exit 1
        # 检查证据清单
        has_evidence_checklist "${VERSION_DIR}review_planning.md" || {
          echo "❌ 阶段推进失败：${VERSION_DIR}review_planning.md 缺少'证据清单'段落或内容为空"
          echo "   请在 review 文件中添加'## 证据清单'段落，列出验证命令和输出（不允许仅包含占位符）"
          exit 1
        }
        ;;
      Implementation)
        if [ "$CHANGE_LEVEL" = "minor" ]; then
          aicoding_run_gate critical "phase-exit:minor-review" validate_minor_review "${VERSION_DIR}review_minor.md" || exit 1
        else
          aicoding_run_gate critical "phase-exit:implementation-review" validate_review_summary_and_coverage "${VERSION_DIR}review_implementation.md" "${VERSION_DIR}requirements.md" "$STATUS_CURRENT_REF" || exit 1
          aicoding_run_gate critical "phase-exit:task-completion" validate_task_completion "${VERSION_DIR}plan.md" "${VERSION_DIR}review_implementation.md" || exit 1
          # 检查证据清单
          has_evidence_checklist "${VERSION_DIR}review_implementation.md" || {
            echo "❌ 阶段推进失败：${VERSION_DIR}review_implementation.md 缺少'证据清单'段落或内容为空"
            echo "   请在 review 文件中添加'## 证据清单'段落，列出验证命令和输出（不允许仅包含占位符）"
            exit 1
          }
          # 重构清单存在性检查
          check_refactoring_checklist_if_needed "$VERSION_DIR" "$CONTENT" || exit 1
        fi
        ;;
      Testing)
        if [ "$CHANGE_LEVEL" = "minor" ]; then
          aicoding_run_gate critical "phase-exit:minor-review" validate_minor_review "${VERSION_DIR}review_minor.md" || exit 1
          aicoding_run_gate critical "phase-exit:minor-test-evidence" validate_minor_test_evidence "$VERSION_DIR" "$CONTENT" || exit 1
          aicoding_run_gate critical "phase-exit:minor-testing-fresh-review" validate_minor_testing_review_freshness "${VERSION_DIR}review_minor.md" || exit 1
          aicoding_run_gate critical "phase-exit:minor-testing-round" validate_minor_testing_round "${VERSION_DIR}review_minor.md" || exit 1
        else
          aicoding_run_gate critical "phase-exit:testing-review" validate_review_summary_and_coverage "${VERSION_DIR}review_testing.md" "${VERSION_DIR}requirements.md" "$STATUS_CURRENT_REF" || exit 1
          aicoding_run_gate critical "phase-exit:test-coverage" validate_test_report_gwt_coverage "${VERSION_DIR}requirements.md" "${VERSION_DIR}test_report.md" || exit 1
          aicoding_run_gate critical "phase-exit:task-completion-testing" validate_task_completion "${VERSION_DIR}plan.md" "${VERSION_DIR}review_testing.md" || exit 1
          # 检查证据清单
          has_evidence_checklist "${VERSION_DIR}review_testing.md" || {
            echo "❌ 阶段推进失败：${VERSION_DIR}review_testing.md 缺少'证据清单'段落或内容为空"
            echo "   请在 review 文件中添加'## 证据清单'段落，列出验证命令和输出（不允许仅包含占位符）"
            exit 1
          }
        fi
        ;;
    esac

    if [ -n "$GATE_MISSING" ]; then
      echo "❌ 阶段出口门禁（${OLD_PHASE} → ${CURRENT_PHASE}）：以下必要产出物缺失："
      echo -e "$GATE_MISSING"
      exit 1
    fi
  done <<< "$STATUS_FILES"
fi

# --- Git-Hook 6: 交付关口条件拦截 ---
# Testing 阶段在 wait_confirm/done/completed 时检查交付必要条件；
# Deployment 阶段在 wait_feedback/done/completed 时检查交付必要条件，
# 同时兼容历史状态文件中的 wait_confirm。
while IFS= read -r f; do
  [ -z "$f" ] && continue
  CONTENT=$(git show ":$f" 2>/dev/null) || continue
  FRONT_MATTER=$(echo "$CONTENT" | awk 'NR==1{next} /^---$/{exit} {print}')
  NEW_CHANGE_STATUS=$(echo "$FRONT_MATTER" | grep '^_change_status:' | sed 's/^_change_status:[[:space:]]*//' | tr -d '[:space:]')
  NEW_RUN_STATUS=$(echo "$FRONT_MATTER" | grep '^_run_status:' | sed 's/^_run_status:[[:space:]]*//' | tr -d '[:space:]')
  NEW_PHASE=$(aicoding_normalize_phase "$(echo "$FRONT_MATTER" | grep '^_phase:' | sed 's/^_phase:[[:space:]]*//' | tr -d '[:space:]')")
  CHANGE_LEVEL=$(echo "$FRONT_MATTER" | grep '^_change_level:' | sed 's/^_change_level:[[:space:]]*//' | tr -d '[:space:]')
  [ -z "$CHANGE_LEVEL" ] && CHANGE_LEVEL="major"
  if [ "$CHANGE_LEVEL" = "hotfix" ]; then
    if [ "$NEW_CHANGE_STATUS" = "done" ] || [ "$NEW_RUN_STATUS" = "completed" ]; then
      aicoding_run_gate critical "delivery:hotfix-test-evidence" validate_hotfix_test_evidence "$CONTENT" || exit 1
    fi
    continue
  fi
  case "$NEW_PHASE" in
    Testing|Deployment) ;;
    *) continue ;;
  esac

  DELIVERY_GATE_TRIGGERED=false
  if [ "$NEW_CHANGE_STATUS" = "done" ] || [ "$NEW_RUN_STATUS" = "completed" ]; then
    DELIVERY_GATE_TRIGGERED=true
  elif [ "$NEW_PHASE" = "Testing" ] && [ "$NEW_RUN_STATUS" = "wait_confirm" ]; then
    DELIVERY_GATE_TRIGGERED=true
  elif [ "$NEW_PHASE" = "Deployment" ] && { [ "$NEW_RUN_STATUS" = "wait_feedback" ] || [ "$NEW_RUN_STATUS" = "wait_confirm" ]; }; then
    DELIVERY_GATE_TRIGGERED=true
  fi
  [ "$DELIVERY_GATE_TRIGGERED" = true ] || continue

  VERSION_DIR=$(aicoding_extract_version_dir_from_path "$f" || true)
  [ -z "$VERSION_DIR" ] && continue

  if [ "$NEW_PHASE" = "Deployment" ]; then
    # 复用单源函数检查 Deployment 出口产出物（当前为 deployment.md）
    while IFS= read -r deploy_doc; do
      [ -z "$deploy_doc" ] && continue
      aicoding_staged_exists "${VERSION_DIR}${deploy_doc}" || {
        echo "❌ 交付关口（wait_feedback/wait_confirm/done/completed）：缺少 ${deploy_doc}"
        exit 1
      }
    done < <(aicoding_phase_exit_required "Deployment" "$CHANGE_LEVEL")

    aicoding_run_gate critical "delivery:deployment-target-env" validate_deployment_target_env "${VERSION_DIR}deployment.md" || exit 1
    aicoding_run_gate critical "delivery:deployment-cr-subset" validate_deployment_cr_subset "${VERSION_DIR}deployment.md" "$CONTENT" || exit 1
    if [ "$NEW_CHANGE_STATUS" = "done" ] || [ "$NEW_RUN_STATUS" = "completed" ]; then
      aicoding_run_gate critical "delivery:deployment-acceptance" validate_deployment_acceptance "${VERSION_DIR}deployment.md" || exit 1
    fi
  fi

  STATUS_CURRENT_REF=$(echo "$FRONT_MATTER" | grep '^_current:' | sed 's/^_current:[[:space:]]*//' | tr -d '[:space:]')
  if [ "$CHANGE_LEVEL" = "minor" ]; then
    aicoding_run_gate critical "delivery:minor-review" validate_minor_review "${VERSION_DIR}review_minor.md" || exit 1
    aicoding_run_gate critical "delivery:minor-test-evidence" validate_minor_test_evidence "$VERSION_DIR" "$CONTENT" || exit 1
    if [ "$NEW_PHASE" = "Deployment" ]; then
      aicoding_run_gate critical "delivery:minor-testing-round" validate_minor_testing_round "${VERSION_DIR}review_minor.md" || exit 1
    fi
    if aicoding_staged_exists "${VERSION_DIR}requirements.md"; then
      if aicoding_staged_content "${VERSION_DIR}requirements.md" | grep -q 'GWT-REQ-C'; then
        aicoding_gate_log_warning "${f}: _change_level=minor 但 requirements 存在 REQ-C，建议升级为 major 并执行 spotcheck"
      fi
    fi
  else
    DELIVERY_MISSING=""
    for doc in review_testing.md test_report.md; do
      aicoding_staged_exists "${VERSION_DIR}${doc}" || DELIVERY_MISSING="${DELIVERY_MISSING}\n  - ${doc}"
    done
    if [ -n "$DELIVERY_MISSING" ]; then
      echo "❌ 交付关口（wait_confirm/done）：以下必要产出物缺失："
      echo -e "$DELIVERY_MISSING"
      exit 1
    fi

    aicoding_run_gate critical "delivery:review-testing" validate_review_summary_and_coverage "${VERSION_DIR}review_testing.md" "${VERSION_DIR}requirements.md" "$STATUS_CURRENT_REF" || exit 1
    aicoding_run_gate critical "delivery:test-report" validate_test_report_gwt_coverage "${VERSION_DIR}requirements.md" "${VERSION_DIR}test_report.md" || exit 1
  fi
done <<< "$STATUS_FILES"

# --- W17 硬拦截: plan.md 任务验证命令检查 ---
PLAN_FILES=$(echo "$STAGED" | grep 'plan\.md$' || true)
if [ -n "$PLAN_FILES" ]; then
  while IFS= read -r pf; do
    [ -z "$pf" ] && continue
    PLAN_CONTENT=$(aicoding_staged_content "$pf")
    [ -z "$PLAN_CONTENT" ] && continue

    MISSING=$(echo "$PLAN_CONTENT" | awk '
      function flush() {
        if(task_title!="" && !has_cmd) {
          missing++
          print "  - " task_title
        }
      }
      /^### (T[0-9]+|任务)/{
        flush()
        task_title=$0
        has_cmd=0
        in_verify=0
        next
      }
      /验证方式/ {in_verify=1}
      in_verify && /人工确认|N\/A|NA（文档类任务）|文档类任务/ {has_cmd=1}
      in_verify && /^- *命令：/{
        if(match($0, /`[^`]+`/)) {
          cmd=substr($0, RSTART+1, RLENGTH-2)
          gsub(/^[ \t]+|[ \t]+$/, "", cmd)
          if(cmd!="" && cmd!="..." && cmd !~ /^<[^>]+>$/) has_cmd=1
        }
      }
      END{
        flush()
      }
    ')

    if [ -n "$MISSING" ]; then
      echo "❌ [W17 硬拦截] 关键节点提交被阻止：plan.md 存在缺少验证命令的任务（请在\"验证方式\"中补充可复现命令）"
      echo "$MISSING" | head -20
      exit 1
    fi
  done <<< "$PLAN_FILES"
fi

# --- Git-Hook 新增: 文档作用域校验（与 CC Gate 3 对齐，堵住 git commit 绕过）---
DOC_FILES=$(
  printf '%s\n' "$STAGED" \
    | while IFS= read -r staged_file; do
        [ -z "$staged_file" ] && continue
        aicoding_extract_version_dir_from_path "$staged_file" >/dev/null 2>&1 || continue
        printf '%s\n' "$staged_file"
      done
)
if [ -n "$DOC_FILES" ]; then
  while IFS= read -r df; do
    [ -z "$df" ] && continue
    DF_VERSION_DIR=$(aicoding_extract_version_dir_from_path "$df" || true)
    [ -z "$DF_VERSION_DIR" ] && continue
    DF_STATUS="${DF_VERSION_DIR}status.md"
    DF_PHASE=$(aicoding_normalize_phase "$(aicoding_staged_content "$DF_STATUS" | awk '
      NR==1 && $0!="---" {exit}
      NR==1 {next}
      /^---$/ {exit}
      /^_phase:/ {sub(/^_phase:[[:space:]]*/, ""); gsub(/[[:space:]]+$/, ""); print; exit}
    ')")
    [ -z "$DF_PHASE" ] && continue
    case "$DF_PHASE" in
      ChangeManagement) DF_ALLOWED="status.md|review_|cr/" ;;
      Proposal)       DF_ALLOWED="status.md|proposal.md|review_|cr/" ;;
      Requirements)   DF_ALLOWED="status.md|requirements.md|proposal.md|review_|cr/" ;;
      Design)         DF_ALLOWED="status.md|design.md|review_|cr/" ;;
      Planning)       DF_ALLOWED="status.md|plan.md|review_|cr/" ;;
      Implementation) DF_ALLOWED="status.md|review_|spotcheck_|cr/|plan.md|tasks/|design.md|requirements.md|implementation_checklist.md|refactoring_checklist.md" ;;
      Testing)        DF_ALLOWED="status.md|test_report.md|review_|spotcheck_|cr/|design.md|requirements.md|plan.md" ;;
      Deployment)     DF_ALLOWED="status.md|deployment.md|test_report.md|review_|spotcheck_|cr/" ;;
      Hotfix)         DF_ALLOWED="status.md|review_|cr/" ;;
      *) continue ;;
    esac
    DF_BASENAME=$(basename "$df")
    DF_MATCH=false
    for pat in $(echo "$DF_ALLOWED" | tr '|' ' '); do
      case "$pat" in
        */) echo "$df" | grep -q "/${pat}" && { DF_MATCH=true; break; } ;;
        *)  [ "$DF_BASENAME" = "$pat" ] && { DF_MATCH=true; break; }
            echo "$DF_BASENAME" | grep -q "^${pat}" && { DF_MATCH=true; break; } ;;
      esac
    done
    if [ "$DF_MATCH" = false ]; then
      echo "❌ 文档作用域校验：当前阶段 ${DF_PHASE}，不允许提交 ${df}。本阶段允许：${DF_ALLOWED//|/, }"
      exit 1
    fi
  done <<< "$DOC_FILES"
fi

# --- Git-Hook 5: git config 防篡改 ---
if echo "$STAGED" | grep -qE '(^|/)\.gitconfig$|(^|/)\.gitmodules$'; then
  echo "❌ 检测到 git 配置文件变更，需人工确认"
  exit 1
fi

# --- Git-Hook 8: 质量债务门禁 ---
# 在新版本进入 Proposal（且无 Active CR）时检查上一版本债务，超过阈值时阻断启动
if [ -x "${SCRIPT_DIR}/../check_quality_debt.sh" ]; then
  "${SCRIPT_DIR}/../check_quality_debt.sh" || exit 1
fi

# --- 新增检查：CR遗漏检查（智能提示版本）---
# 检查代码变更涉及核心文件，但status.md中无Active CR时提示
staged_code_files=$(git diff --cached --name-only | aicoding_regex_search lines "frontend/src/pages/|backend/app/api/|backend/app/models/|frontend/src/components/" || true)

if [ -n "$staged_code_files" ]; then
  # 检查commit message类型，排除明显不需要CR的场景
  commit_msg_file=".git/COMMIT_EDITMSG"
  commit_msg=""
  if [ -f "$commit_msg_file" ]; then
    commit_msg=$(head -1 "$commit_msg_file" 2>/dev/null || echo "")
  fi

  # 如果是refactor/test/chore/docs类型，跳过检查
  if echo "$commit_msg" | grep -qE "^(refactor|test|chore|docs|style|build|ci):"; then
    : # 跳过检查
  else
    # 检查status.md中是否有Active CR
    has_active_cr=false
    for status_file in docs/*/status.md; do
      if [ -f "$status_file" ]; then
        if aicoding_regex_search quiet "^\| CR-[0-9]{8}-[0-9]{3} \| (Accepted|In Progress)" "$status_file" 2>/dev/null; then
          has_active_cr=true
          break
        fi
      fi
    done

    if [ "$has_active_cr" = "false" ]; then
      echo ""
      echo "💡 提示：代码变更涉及核心文件，建议确认是否需要创建 CR"
      echo ""
      echo "   变更的核心文件："
      echo "$staged_code_files" | sed 's/^/     - /'
      echo ""
      echo "   如果是新功能/优化，请创建 CR（docs/<版本号>/cr/CR-YYYYMMDD-NNN.md）"
      echo "   如果是重构/bug修复/测试，可以跳过"
      echo ""
    fi
  fi
fi

aicoding_gate_log_pass "pre-commit"
exit 0

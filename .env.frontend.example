# 前端环境变量配置（独立部署）
# 复制此文件为 .env.frontend 并修改配置

# ========== 后端API地址 ==========
# 部署时需要替换为实际的后端服务器地址
# 示例：
# - http://192.168.1.100:443
# - https://api.yourdomain.com
REACT_APP_API_URL=https://backend.yourdomain.com

# ========== 内网前端 nginx 后端代理 ==========
# deploy-frontend-internal.sh 会读取该值并渲染 frontend/nginx.internal.runtime.conf
# 格式：<后端IP或域名>:<端口>，不要填写 /api 路径
FRONTEND_BACKEND_UPSTREAM=10.62.22.121:443
